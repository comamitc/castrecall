# CastRecall environment variables.
# Copy to .env (or export in the environment OpenClaw runs in) and fill in
# what you use. Secrets are env-only by design — they never go through
# OpenClaw plugin config, and CastRecall never logs or stores them.
#
# Prefer letting an agent walk you through this: ask it to run
# castrecall_setup, which explains each variable below in context and can
# verify Pocket Casts credentials with a read-only test call. It never edits
# openclaw.json or writes secrets to disk.

# --- Pocket Casts (required for history sync) -------------------------------
# Read-only access to your listening history via the UNOFFICIAL web-player
# API. Accounts created with "Sign in with Google/Apple" have no password and
# cannot be used until Pocket Casts ships an official API.
POCKETCASTS_EMAIL=
POCKETCASTS_PASSWORD=

# --- Storage ----------------------------------------------------------------
# Where transcripts, provenance, and review candidates live.
# Default: ~/.openclaw/castrecall
#CASTRECALL_DATA_DIR=

# Max history entries ingested per sync (default 100).
#CASTRECALL_HISTORY_LIMIT=100

# --- Corpus export (optional, off by default) --------------------------------
# When set, storing a transcript also writes section-split, frontmattered
# markdown pages here — for gbrain, Obsidian vaults, or other markdown-native
# corpora. See README "Corpus export" for the two gbrain placements.
#CASTRECALL_EXPORT_DIR=

# --- Transcript ladder rung 2: Taddy (optional) ------------------------------
# Free signup at https://taddy.org/developers. Podcast-provided transcripts may
# be available to free accounts; generated/on-demand transcripts use Taddy plan
# credits. Skipped with a clear message when unset.
#TADDY_API_KEY=
#TADDY_USER_ID=

# --- Transcript ladder rung 3: local Whisper (free, private) -----------------
# Auto-detected: whisper-cli / whisper-cpp (whisper.cpp), mlx_whisper,
# whisper-ctranslate2, or whisper (openai-whisper) on PATH. Nothing to set
# unless you want to customize.

# whisper.cpp needs a ggml model file; other CLIs accept a model name here.
#CASTRECALL_WHISPER_MODEL=/path/to/ggml-base.en.bin

# Or run any command you like; {input} = audio file path, stdout = transcript.
#CASTRECALL_WHISPER_COMMAND=whisper-cli -m /path/to/model.bin -f {input} -np -nt

# Skip local Whisper even when a CLI is installed.
#CASTRECALL_DISABLE_LOCAL_WHISPER=true

# --- Transcript ladder rung 4: cloud speech-to-text (optional, COSTS MONEY) --
# Disabled by default. Enable explicitly, then configure ONE provider.
#CASTRECALL_ENABLE_STT=true
#CASTRECALL_STT_PROVIDER=assemblyai   # assemblyai (default) | openai

# AssemblyAI transcribes straight from the episode's audio URL (recommended).
#ASSEMBLYAI_API_KEY=

# OpenAI requires downloading + uploading the audio (25 MB API limit).
#OPENAI_API_KEY=
#CASTRECALL_OPENAI_STT_MODEL=gpt-4o-transcribe
