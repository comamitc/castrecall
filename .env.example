# CastRecall environment variables.
# Copy to .env (or export in the environment OpenClaw runs in) and fill in
# what you use. Secrets never go through OpenClaw plugin config, and
# CastRecall never logs or stores them beyond the OS keychain described below.
#
# Prefer letting an agent walk you through this: ask it to run
# castrecall_setup, which explains each variable below in context and can
# verify Pocket Casts credentials with a read-only test call. It never edits
# openclaw.json or writes secrets to disk itself.

# --- Pocket Casts (required for history sync) -------------------------------
# Read-only access to your listening history via the UNOFFICIAL web-player
# API. Accounts created with "Sign in with Google/Apple" have no password and
# cannot be used until Pocket Casts ships an official API.
#
# Credentials are keychain-preferred: when an OS keychain backend is detected
# (macOS Keychain / libsecret), CastRecall reads pocketcasts-email /
# pocketcasts-password from it instead. The two env vars below are the
# portable fallback used when no keychain entry is found. See README
# "Credential storage" for the exact keychain store commands.
POCKETCASTS_EMAIL=
POCKETCASTS_PASSWORD=

# Disable the durable OS keychain sink (credential reads + token persistence).
# The in-memory, process-lifetime session-token cache still applies.
#CASTRECALL_DISABLE_KEYCHAIN=

# Service name under which OS keychain entries are stored (default castrecall).
#CASTRECALL_SECRET_SERVICE=

# --- Storage ----------------------------------------------------------------
# Where transcripts, provenance, and review candidates live.
# Default: ~/.openclaw/castrecall
#CASTRECALL_DATA_DIR=

# Max history entries ingested per sync (default 100).
#CASTRECALL_HISTORY_LIMIT=100

# --- Transcript cleanup pass (on by default) ---------------------------------
# Deterministic punctuation/caption-artifact/whitespace cleanup applied to
# transcript.txt before storage — never paraphrases, summarizes, or adds
# facts. raw.<ext> is always kept verbatim regardless. Set to false to store
# transcript.txt exactly as normalized, with no cleanup pass. See README
# "Transcript cleanup pass".
#CASTRECALL_TRANSCRIPT_CLEANUP=true

# --- Proper-noun correction glossary (off unless configured) -----------------
# Optional path to a JSON file of known STT mangling corrections for product
# names, people, and companies. Applied after cleanup; corrections are
# recorded in provenance.glossary. See README "Proper-noun correction
# glossary". File shape:
#   { "terms": [ { "canonical": "ChatGPT", "variants": ["chat gpt", "chatgpt"] } ] }
#CASTRECALL_GLOSSARY_FILE=

# --- Listened-episode filter (applies to newly ingested episodes only; ------
# --- never retroactively removes already-stored episodes/transcripts) -------
# An episode with playingStatus == 3 (fully played) is always recorded.
# Otherwise it needs playedUpTo/duration >= this ratio (default 0.8).
#CASTRECALL_MIN_LISTEN_RATIO=0.8

# When duration is missing/unusable, accept if playedUpTo is at least this
# many seconds (default 300).
#CASTRECALL_MIN_LISTEN_SECONDS=300

# Record episodes with no usable duration, playedUpTo, or playingStatus at
# all. Off by default (they are skipped).
#CASTRECALL_RECORD_UNKNOWN_LISTENS=

# --- Corpus export (optional, off by default) --------------------------------
# When set, storing a transcript also writes section-split, frontmattered
# markdown pages here — for gbrain, Obsidian vaults, or other markdown-native
# corpora. See README "Corpus export" for the two gbrain placements.
#CASTRECALL_EXPORT_DIR=

# --- Notes destination for castrecall_resolve_review (required for promote) --
# Where promoted notes are written when a human confirms, in conversation,
# what to keep from a review candidate. Created on demand if it doesn't exist
# yet. Never required for disposition: "discard". See README "Resolving
# reviews".
#CASTRECALL_NOTES_DIR=

# Set by an agent-driven wrapper that has confirmed a gbrain plugin install via
# OpenClaw's own plugin inventory (castrecall_setup cannot detect this itself).
#CASTRECALL_GBRAIN_INSTALLED=

# --- Feed-URL discovery fallback: Listen Notes (optional) --------------------
# Not a transcript-ladder rung — Listen Notes' own docs say under 1% of
# episodes have transcripts. Used only when both the Pocket Casts feed-export
# endpoint and iTunes Search fail to resolve the podcast's RSS feed URL.
# Free signup at https://www.listennotes.com/api/.
#LISTENNOTES_API_KEY=

# --- Transcript ladder rung 2: Taddy (optional) ------------------------------
# Free signup at https://taddy.org/developers. Podcast-provided transcripts may
# be available to free accounts; generated/on-demand transcripts use Taddy plan
# credits. Skipped with a clear message when unset.
#TADDY_API_KEY=
#TADDY_USER_ID=

# --- Transcript ladder rung 3: Podchaser (optional) --------------------------
# PODCHASER_API_KEY is a bearer access token, NOT a client secret: mint it once
# via Podchaser's requestAccessToken mutation (client_credentials grant), then
# paste the resulting access_token here — it's valid for about a year. See
# https://api-docs.podchaser.com/docs/authorization/. Skipped with a clear
# message when unset.
#PODCHASER_API_KEY=

# --- Transcript ladder rung 4: local Whisper (free, private) -----------------
# Auto-detected: whisper-cli / whisper-cpp (whisper.cpp), mlx_whisper,
# whisper-ctranslate2, or whisper (openai-whisper) on PATH. Nothing to set
# unless you want to customize.

# CUDA/NVIDIA machines (e.g. an RTX 5090): skip MLX — its presets resolve to
# mlx-community models that only run on mlx_whisper (Apple Silicon). Instead
# let whisper-ctranslate2 (faster-whisper's CLI) auto-detect and set
# CASTRECALL_WHISPER_MODEL=large-v3 below; CastRecall passes no --device flag,
# so the CLI picks the GPU on its own. To pin --device/--compute_type, or to
# run WhisperX instead (not auto-detected), use CASTRECALL_WHISPER_COMMAND.
# WhisperX's CLI writes a transcript file rather than printing to stdout, so
# the command needs a wrapper that cats the result:
#   CASTRECALL_WHISPER_COMMAND=out=$(mktemp -d) && whisperx {input} --device cuda --compute_type float16 --model large-v3 --output_format txt --output_dir "$out" >&2 && cat "$out"/*.txt

# Model to use, by platform/backend:
#   whisper.cpp                 -> ggml model file path
#   whisper-ctranslate2 (CUDA)  -> model name, e.g. large-v3
#   mlx_whisper (Apple Silicon) -> mlx-community/... model, or use a preset below
# Avoid tiny/base ggml models (e.g. ggml-base.en.bin) for corpus-scale
# transcription — they're low-quality and only appropriate for a quick smoke
# test.
#CASTRECALL_WHISPER_MODEL=/path/to/ggml-large-v3.bin

# Apple Silicon (mlx_whisper) only: a CastRecall-managed quality preset instead
# of naming a model yourself. Ignored by whisper.cpp/openai-whisper/ctranslate2
# (including CUDA hosts) — mlx-community models are not valid there; use
# CASTRECALL_WHISPER_MODEL instead (e.g. large-v3 for whisper-ctranslate2).
#   best     -> mlx-community/whisper-large-v3-turbo (quality-approved default)
#   balanced -> mlx-community/whisper-large-v3-turbo (aliases best today)
#   fast     -> mlx-community/whisper-small-mlx (explicit lower-quality opt-in)
# CASTRECALL_WHISPER_MODEL always overrides this when both are set.
#CASTRECALL_LOCAL_WHISPER_PRESET=best

# Or run any command you like; {input} = audio file path, stdout = transcript.
# A custom command ignores every CASTRECALL_WHISPER_* decode option below —
# you own the whole command line.
#CASTRECALL_WHISPER_COMMAND=whisper-cli -m /path/to/model.bin -f {input} -np -nt

# Skip local Whisper even when a CLI is installed.
#CASTRECALL_DISABLE_LOCAL_WHISPER=true

# Loop-safe decoding options (issue #53): Whisper's defaults are tuned for
# short clips, not hour-long podcasts, and can produce repetition loops or
# hallucinated text. An option a detected flavor doesn't support is ignored
# with an explicit reason (surfaced in castrecall_setup/_status and the
# ladder rung detail), never silently dropped or a hard failure.

# Language hint (e.g. "en") — unset auto-detects.
#CASTRECALL_WHISPER_LANGUAGE=en

# Default false: CastRecall's loop-prevention default for long-form audio —
# feeding prior output back in as decoding context is a primary driver of
# Whisper repetition loops. Set true to opt back into the CLI's own default.
#CASTRECALL_WHISPER_CONDITION_ON_PREVIOUS_TEXT=false

# Word-level timestamps where the flavor supports it. On whisper.cpp this maps
# to its full-JSON -ojf output, so it only takes effect when
# CASTRECALL_WHISPER_OUTPUT_FORMAT=json (otherwise ignored with a reason).
#CASTRECALL_WHISPER_WORD_TIMESTAMPS=true

# txt (default), or json/vtt/srt for structured/timestamped output, parsed
# the same way RSS transcripts are. An unrecognized value falls back to txt
# with the ignored value named in provenance.
#CASTRECALL_WHISPER_OUTPUT_FORMAT=txt

# Hallucination/silence thresholds. logprobThreshold maps to whisper.cpp's
# -lpt; compressionRatioThreshold and hallucinationSilenceThreshold are not
# supported by whisper.cpp (ignored with a reason). hallucinationSilenceThreshold
# also requires CASTRECALL_WHISPER_WORD_TIMESTAMPS=true on mlx-whisper/
# openai-whisper/whisper-ctranslate2, or it's ignored with a reason. An
# invalid (non-numeric) value is dropped, not passed through as NaN.
#CASTRECALL_WHISPER_NO_SPEECH_THRESHOLD=0.6
#CASTRECALL_WHISPER_LOGPROB_THRESHOLD=-1.0
#CASTRECALL_WHISPER_COMPRESSION_RATIO_THRESHOLD=2.4
#CASTRECALL_WHISPER_HALLUCINATION_SILENCE_THRESHOLD=2.0

# After a run, audit what actually produced each transcript — see README
# Troubleshooting: "How do I audit what actually produced a transcript after a
# run?" (reads provenance.json's `generation` object).

# --- Transcript ladder rung 5: cloud speech-to-text (optional, COSTS MONEY) --
# Disabled by default. Enable explicitly, then configure ONE provider.
#CASTRECALL_ENABLE_STT=true
#CASTRECALL_STT_PROVIDER=assemblyai   # assemblyai (default) | openai | deepgram | remote-stt

# AssemblyAI transcribes straight from the episode's audio URL (recommended).
#ASSEMBLYAI_API_KEY=

# OpenAI requires downloading + uploading the audio (25 MB API limit).
#OPENAI_API_KEY=
#CASTRECALL_OPENAI_STT_MODEL=gpt-4o-transcribe

# Deepgram transcribes straight from the episode's audio URL, like AssemblyAI,
# with diarized speaker labels.
#DEEPGRAM_API_KEY=
#CASTRECALL_DEEPGRAM_STT_MODEL=nova-3

# remote-stt (issue #61): a generic contract for your own private/self-hosted
# STT service (WhisperX, faster-whisper, ...) — see README "Remote STT
# contract" for the exact request/response shapes. Transcribes straight from
# the episode's audio URL by default; set the upload flag below for a service
# that cannot fetch remote URLs itself.
#CASTRECALL_REMOTE_STT_BASE_URL=
#CASTRECALL_REMOTE_STT_TOKEN=
#CASTRECALL_REMOTE_STT_MODEL=
#CASTRECALL_REMOTE_STT_UPLOAD=false
