# castrecall-whisperx-worker environment.
# Copy to .env next to docker-compose.yml. This is the WORKER's own env —
# separate from CastRecall's .env (see the root .env.example's
# CASTRECALL_REMOTE_STT_* section for how to point CastRecall at this worker).

# Required — the worker refuses to start without it. Every endpoint,
# including /health, requires `Authorization: Bearer <token>`. Generate one
# with: openssl rand -hex 32
WORKER_TOKEN=

# Model name WhisperX loads by default (a request's own "model" field
# overrides this per-job).
WHISPERX_MODEL=large-v3

# Optional language hint (e.g. "en"); unset auto-detects.
#WHISPERX_LANGUAGE=

# Batch size the WhisperX pipeline decodes with.
WHISPERX_BATCH_SIZE=16

# float16 (default, needs a CUDA device with fp16 support), int8, or float32.
WHISPERX_COMPUTE_TYPE=float16

# Speaker diarization default (a request's own "diarize" field overrides
# this per-job). Needs HF_TOKEN below — without it, diarize requests still
# succeed but return a transcript with no speaker labels plus a warning.
WHISPERX_DIARIZE=false

# HuggingFace access token with the pyannote speaker-diarization model
# terms accepted, required only when WHISPERX_DIARIZE (or a request's
# diarize field) is true. https://huggingface.co/pyannote/speaker-diarization
#HF_TOKEN=

# Delete each job's temporary downloaded/uploaded audio file once the job
# finishes (success or failure). Set false only for local debugging — never
# in a shared/always-on deployment.
DELETE_AUDIO=true

# A single CUDA device can usefully run one WhisperX transcription at a
# time; raise this only on a multi-GPU host with per-job device pinning
# (not implemented in this reference worker).
MAX_ACTIVE_JOBS=1

# Jobs queued or processing beyond this are rejected with 429 (which
# CastRecall's remote-stt provider treats as retryable).
MAX_QUEUED_JOBS=16

# Port docker-compose publishes to 127.0.0.1 on the host (see
# docker-compose.yml "Network exposure").
WORKER_PORT=8000
