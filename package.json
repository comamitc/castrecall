{
  "name": "castrecall",
  "version": "0.6.0",
  "description": "CastRecall — turn podcast listening into retrievable memory. An OpenClaw tool plugin that ingests Pocket Casts listens, finds or generates transcripts, and creates approval-gated review candidates.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/comamitc/castrecall.git"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "podcast",
    "transcripts",
    "pocket-casts",
    "memory"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "plugin:build": "npm run build && openclaw plugins build --entry ./dist/index.js",
    "plugin:validate": "npm run build && openclaw plugins validate --entry ./dist/index.js"
  },
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md",
    ".env.example",
    "docs",
    "LICENSE"
  ],
  "peerDependencies": {
    "openclaw": ">=2026.6.11"
  },
  "dependencies": {
    "fast-xml-parser": "^5.2.0",
    "typebox": "^1.1.38"
  },
  "devDependencies": {
    "openclaw": "latest",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "install": {
      "clawhubSpec": "clawhub:comamitc/castrecall",
      "localPath": ".",
      "defaultChoice": "clawhub",
      "minHostVersion": ">=2026.6.11"
    },
    "compat": {
      "pluginApi": ">=2026.6.11"
    },
    "build": {
      "openclawVersion": "2026.6.11",
      "pluginSdkVersion": "2026.6.11"
    }
  }
}
